<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scrollUpload"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@android:color/white"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <TextView
            android:id="@+id/tvUploadHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/upload_page_title"
            android:textAlignment="center"
            android:textSize="30sp"
            android:textColor="@color/black"
            android:layout_marginVertical="20dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/black"
            android:layout_marginBottom="16dp"/>


        <!-- Location input -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/location_upload"
            android:textColor="@color/black"
            android:textSize="19sp"
            android:paddingBottom="8dp"/>

        <!-- The actual textbox with placeholder -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilLocation"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:boxStrokeColor="@color/black"
            android:paddingBottom="16dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/location_hint"
                android:inputType="textPostalAddress|textNoSuggestions"
                android:privateImeOptions="noPersonalizedLearning"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Two dropdowns side by side: Type & Roast Level -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="16dp">

            <!-- Type block -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- Static label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/type_upload"
                    android:textColor="@color/black"
                    android:textSize="19sp"
                    android:paddingBottom="4dp"/>

                <!-- Dropdown -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilType"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:boxStrokeColor="@color/black"
                    app:endIconMode="dropdown_menu">

                    <AutoCompleteTextView
                        android:id="@+id/actvType"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/type_hint"
                        android:inputType="none"/>
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- Spacer -->
            <View
                android:layout_width="16dp"
                android:layout_height="0dp"/>

            <!-- Roast Level block -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- Static label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/roast_level"
                    android:textColor="@color/black"
                    android:textSize="19sp"
                    android:paddingBottom="4dp"/>

                <!-- Dropdown -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:boxStrokeColor="@color/black"
                    app:endIconMode="dropdown_menu">

                    <AutoCompleteTextView
                        android:id="@+id/actvRoast"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/roast_hint"
                        android:inputType="none"/>
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Origin -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <!-- Static “Origin” label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/origin"
                android:textColor="@color/black"
                android:textSize="19sp"
                android:paddingBottom="4dp"/>

            <!-- Outlined input -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:boxStrokeColor="@color/black">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etOrigin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/origin_hint"
                    android:inputType="text|textNoSuggestions"
                    android:privateImeOptions="noPersonalizedLearning"/>
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Process -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <!-- Static “Process” label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/process"
                android:textColor="@color/black"
                android:textSize="19sp"
                android:paddingBottom="4dp"/>

            <!-- Outlined input -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:boxStrokeColor="@color/black">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etProcess"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/process_hint"
                    android:inputType="text|textNoSuggestions"
                    android:privateImeOptions="noPersonalizedLearning"/>
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Static “Upload an Image” label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/upload_an_image"
                android:textColor="@color/black"
                android:textSize="19sp"
                android:paddingBottom="10dp"/>

            <!-- Upload an Image area -->
            <FrameLayout
                android:id="@+id/flImageUpload"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/upload_box_bg"
                android:padding="0dp">

                <!-- smaller, centered placeholder -->
                <ImageView
                    android:id="@+id/ivUploadIcon"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerInside"
                    android:adjustViewBounds="true"
                    android:src="@drawable/image_1"
                    app:tint="@color/black"
                    android:layout_gravity="center" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvImageError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/design_default_color_error"
                android:textSize="12sp"
                android:paddingTop="4dp"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- Submit button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubmitUpload"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="match_parent"
            android:layout_height="69dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:text="@string/upload"
            android:backgroundTint="@color/black"
            android:textColor="@android:color/white"
            app:cornerRadius="32dp"/>
    </LinearLayout>
</ScrollView>
