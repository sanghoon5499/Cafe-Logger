<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.CafeLogger" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/black</item>
        <item name="colorPrimaryVariant">#FF914D</item>
        <item name="colorOnPrimary">#FFD93D</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">#4CCD6E</item>
        <item name="colorSecondaryVariant">#3DCFD3</item>
        <item name="colorOnSecondary">#4B7BFF</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/white</item>
        <!-- Customize your theme here. -->
    </style>

    <style name="Theme.CafeLogger.NoActionBar">
        <!-- Hide the ActionBar -->
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>

        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/black</item>            <!-- Text above text input -->
        <item name="colorPrimaryVariant">#FF914D</item>
        <item name="colorOnPrimary">#FFD93D</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">#4CCD6E</item>
        <item name="colorSecondaryVariant">#3DCFD3</item>
        <item name="colorOnSecondary">#4B7BFF</item>

        <item name="android:windowBackground">@android:color/white</item>
        <item name="android:statusBarColor">@color/white</item>

        <!-- <item name="android:statusBarColor">#FF4B4B</item>   not working? -->
    </style>

</resources>